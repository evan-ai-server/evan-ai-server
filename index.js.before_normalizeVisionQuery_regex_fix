function withTimeout(ms) {
  const controller = new AbortController();
  const id = setTimeout(() => controller.abort(), ms);
  return { signal: controller.signal, cancel: () => clearTimeout(id) };
}

function clamp01(n) {
  return Math.max(0, Math.min(1, n));
}

function safeStr(s, max = 180) {
  if (typeof s !== "string") return "";
  const t = s.trim();
  return t.length > max ? t.slice(0, max) : t;
}

function normalizeQuery(q = "") {
  return String(q)
    .toLowerCase()
    .replace(/\b(used|cheap|deal|best price|sale)\b/g, "")
    .replace(/\s+/g, " ")
    .trim();
}

function normalizeVisionQuery(query, mode = "item") {
  if (mode !== "item") return query;

  const q = String(query || "").toLowerCase().trim();
  if (!q) return null;

  const hasBlue =
    q.includes("blue light") ||
    q.includes("blue-light") ||
    q.includes("computer") ||
    q.includes("screen");

  const hasOrange =
    q.includes("orange") ||
    q.includes("amber");

  const hasClear =
    q.includes("clear");

  const hasSun =
    q.includes("sunglass") ||
    q.includes("aviator") ||
    q.includes("shade") ||
    q.includes("uv");

  if (hasBlue) return "glasses";
  if (hasClear) return "glasses";
  if (hasOrange && !hasSun) return "glasses";
  if (hasSun && !hasBlue) return "glasses";

  if (
    q.includes("glasses") ||
    q.includes("eyewear") ||
    q.includes("frames") ||
    q.includes("spectacles")
  ) {
    return "glasses";
  }

  return query;
}


function sha256(buf) {
  return crypto.createHash("sha256").update(buf).digest("hex");
}

function resaleScore(items) {
  if (!items.length) return 0;
  const prices = items.map(i => i.price).filter(Boolean);
  if (!prices.length) return 0;

  const spread = Math.max(...prices) - Math.min(...prices);
  const avg = prices.reduce((a,b)=>a+b,0)/prices.length;

  return spread / avg;
}

