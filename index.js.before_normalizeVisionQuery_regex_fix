      results.push({
        query: q,
        bestPrice: items[0]?.price ?? null,
        best: items[0] ?? null,
      });
    }

    return res.status(200).json({ ok: true, results });
  } catch {
    return res.status(200).json({ ok: false, error: "batch_check_failed" });
  }
});

