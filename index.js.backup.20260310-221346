    "goggles",
    "phototherapy",
    "therapy glasses",
    "filter glasses",
    "inspection glasses",
    "exam glasses",
  ];

  if (hardRejectWords.some((w) => t.includes(w))) return true;

  const sportWords = [
    "cycling",
    "running",
    "baseball",
    "golf",
