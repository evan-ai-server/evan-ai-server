// -------------------- ETSY SEARCH --------------------
async function etsySearch(query) {
  if (!ETSY_API_KEY) return [];
  if (Date.now() < ETSY_COOLDOWN_UNTIL) return [];
  if (isSourceCoolingDown("etsy")) return [];

  const startedAt = Date.now();

  const controller = new AbortController();
  const t = setTimeout(() => controller.abort(), 7000);

  try {
    const url =
      "https://openapi.etsy.com/v3/application/listings/active?" +
      new URLSearchParams({
        keywords: query,
        limit: "48",
      });

    const r = await fetch(url, {
      signal: controller.signal,
      headers: {
        "x-api-key": ETSY_API_KEY,
      },
    });

if (r.status === 429) {
  ETSY_COOLDOWN_UNTIL = Date.now() + 90 * 1000;
  markSourceFailure("etsy", "http_429");
  console.warn("⚠️ Etsy rate limited. Cooling down for 90s.");
  return [];
}

if (r.status === 403) {
  ETSY_COOLDOWN_UNTIL = Date.now() + 10 * 60 * 1000;
  console.warn("⚠️ Etsy 403. Key/app access rejected. Disabling Etsy for 10m.");
  return [];
}

if (!r.ok) {
  markSourceFailure("etsy", `http_${r.status}`);
  console.warn("⚠️ Etsy request failed:", r.status);
  return [];
}

    const data = await r.json();

    const raw = (Array.isArray(data?.results) ? data.results : []).map((x) => {
      const amount = Number(x?.price?.amount ?? x?.price_amount ?? 0);
      const divisor = Number(x?.price?.divisor ?? 100) || 100;

      return {
        title: x?.title || null,
        extracted_price: amount > 0 ? amount / divisor : null,
        source: "etsy",
        link: x?.url || null,
        thumbnail:
          x?.images?.[0]?.url_fullxfull ||
          x?.images?.[0]?.url_570xN ||
          null,
        rating: x?.shop?.review_average ?? null,
        reviews: x?.shop?.review_count ?? null,
      };
    });

    let items = raw
      .map(normalizeItem)
      .filter((x) => x.title && x.link);

    items = items.filter((it) => !isBadListing(it.title, query));
    items = trimPriceOutliers(items);
    items = dedupeSmart(items);
    items = sortByAbsoluteCheapest(items, query);

    markSourceSuccess("etsy", Date.now() - startedAt);

    return items.slice(0, 60);
  } catch (err) {
    markSourceFailure(
      "etsy",
      err?.name === "AbortError" ? "timeout" : "exception"
    );
    console.warn("⚠️ Etsy search error:", err?.message || err);
    return [];
  } finally {
    clearTimeout(t);
  }
}

async function serpEbaySearch(query) {
  if (!SERPAPI_KEY) return [];
  if (isSourceCoolingDown("serpapi")) return [];

  const baseQuery = normalizeQuery(query);
  if (!baseQuery) return [];

  const wantsOrange =
    baseQuery.includes("orange") ||
    baseQuery.includes("amber") ||
    baseQuery.includes("yellow");

  const wantsBlue =
    baseQuery.includes("blue light") ||
    baseQuery.includes("blue-light") ||
    baseQuery.includes("computer") ||
    baseQuery.includes("gaming") ||
    baseQuery.includes("block blue") ||
    baseQuery.includes("screen");

  const wantsWrap = baseQuery.includes("wrap");

  const attempts = [
    `${baseQuery} site:ebay.com`,
    `${baseQuery} pre owned site:ebay.com`,
    `${baseQuery} vintage site:ebay.com`,
    `${baseQuery} retro site:ebay.com`,
  ];

  if (wantsOrange && wantsWrap && !wantsBlue) {
    attempts.push("orange wraparound sunglasses site:ebay.com");
    attempts.push("black wraparound orange lens sunglasses site:ebay.com");
    attempts.push("y2k orange lens wraparound sunglasses site:ebay.com");
  }

  const dedupedAttempts = [...new Set(
    attempts
      .map((x) => String(x).toLowerCase().replace(/\s+/g, " ").trim())
      .filter(Boolean)
  )];

  let merged = [];

  for (const q of dedupedAttempts) {
    const rows = await serpShopping(q, { bypassCooldown: true, softFail: true });
    if (!rows?.length) continue;

    merged.push(...rows);

    if (merged.length >= 48) break;
  }

  merged = dedupeSmart(merged);
  merged = filterRelevantListings(baseQuery, merged);
  merged = trimPriceOutliers(merged);
  merged = intuitionFilter(merged);
  merged = sortByAbsoluteCheapest(merged, baseQuery);

  return merged.slice(0, 60);
}

