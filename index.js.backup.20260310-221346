  ];

  if (fashionOrangeWrap && sportWords.some((w) => t.includes(w))) return true;
  if (fashionOrangeWrap && titleLooksBlue && !allowBlueFallback) return true;

  // if query clearly wants sunglasses, aggressively reject optical/computer junk
