// watch poll (frontend expects this)
app.post("/watch/poll", async (req, res) => {
  try {
    const userId = safeStr(req.body?.userId, 64);
    const items = Array.isArray(req.body?.items) ? req.body.items : [];

    if (!userId || !items.length) {
      return res.status(200).json({ ok: true, drops: [], updated: [] });
    }

    const cleaned = items
      .map((it) => ({
        id: it?.id || null,
        query: normalizeQuery(safeStr(it?.query || it?.title, 220)),
      }))
      .filter((it) => it.query)
      .slice(0, 25);

    const drops = [];
    const updated = [];

    for (const it of cleaned) {
      const result = await runWatchCheck(userId, it.query);
      if (!result) continue;

      updated.push({
        id: it.id || result.query,
        query: result.query,
        bestPrice: result.bestPrice,
        best: result.best,
        delta: result.delta,
        state: result.state,
        consensus: result.consensus,
      });

      if (result.delta?.priceDropped && result.delta?.significant) {
        drops.push({
          id: it.id || result.query,
          query: result.query,
          bestPrice: result.bestPrice,
          best: result.best,
          delta: result.delta,
          consensus: result.consensus,
        });
      }
    }

    return res.status(200).json({
      ok: true,
      drops,
      updated,
    });
  } catch {
    return res.status(200).json({ ok: true, drops: [], updated: [] });
  }
});

